# ===========================================================
#  the-five-agents — משתני סביבה (תבנית)
#  העתק קובץ זה ל-.env ומלא את הערכים האמיתיים.
#  אין להעלות את .env ל-git — הוא מכיל סודות.
# ===========================================================

# --- Claude / Anthropic — המוח של כל הצוות (ראובן + הסוכנים) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# מודל ברירת מחדל לסוכנים
ANTHROPIC_MODEL=claude-opus-4-8

# --- יובל — מעצב התמונות (יצירת תמונות) ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- חן — החוקרת (חיפוש ומחקר באינטרנט) ---
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- הגדרות כלליות ---
# סביבה: development | production
APP_ENV=development
LOG_LEVEL=info
